{
  "name": "ai-release-notes",
  "version": "0.0.2",
  "description": "Generic AI-powered release notes generator using Vercel AI SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ai-release-notes": "dist/bin/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "prompts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin/cli.ts",
    "lint": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "release-notes",
    "changelog",
    "ai",
    "llm",
    "git",
    "vercel-ai-sdk",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.17",
    "@ai-sdk/google": "^4.0.20",
    "@ai-sdk/mistral": "^4.0.14",
    "@ai-sdk/openai": "^4.0.17",
    "ai": "^7.0.33",
    "chalk": "^5.3.0",
    "clipboardy": "^5.3.1",
    "commander": "^15.0.0",
    "ora": "^9.4.1",
    "simple-git": "^3.25.0",
    "yaml": "^2.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.1",
    "conventional-changelog-cli": "^5.0.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "husky": "^9.1.7",
    "tsx": "^4.15.0",
    "typescript": "^7.0.2"
  },
  "peerDependencies": {
    "ai": "^7.0.33"
  }
}
