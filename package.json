{
  "name": "ai-release-notes",
  "version": "1.0.0",
  "description": "Generic AI-powered release notes generator using Vercel AI SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ai-release-notes": "dist/bin/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "prompts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin/cli.ts",
    "lint": "tsc --noEmit",
    "test": "tsx --test test/release.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "release-notes",
    "changelog",
    "ai",
    "llm",
    "git",
    "vercel-ai-sdk",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/mistral": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "ai": "^4.0.0",
    "chalk": "^5.3.0",
    "clipboardy": "^5.3.1",
    "commander": "^12.0.0",
    "ora": "^8.0.0",
    "simple-git": "^3.25.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "ai": "^4.0.0"
  }
}
